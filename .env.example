# =============================================================================
# Variables d'environnement — copier vers .env (jamais commité)
# =============================================================================

# --- SQL Server ---
SQL_SERVER=mssql-205717-0.cloudclusters.net
SQL_PORT=10053
SQL_DATABASE=GP3R_Tirages
SQL_USER=Y450
SQL_PASSWORD=changeme
SQL_TRUST_CERT=true

# --- JWT ---
# IMPORTANT: générer une clé aléatoire de 64+ caractères
# Linux/Mac: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changeme_generate_a_long_random_string_at_least_64_chars

# --- CORS ---
# Origines autorisées, séparées par virgule. Utiliser * uniquement en dev.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Server (dev local seulement, ignoré sur Vercel) ---
PORT=3000
